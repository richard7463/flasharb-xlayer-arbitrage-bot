# ========================================
# DexFight X Layer - 环境变量配置
# ========================================
# 复制为 .env 后填写

# ====== 1. OKX Onchain OS (必需) ======
# 在 https://www.okx.com/onchainos 注册获取
ONCHAINOS_API_KEY=your_okx_api_key

# ====== 2. Wallet (必需) ======
# 你的私钥 (带 0x 前缀)
PRIVATE_KEY=0xyour_private_key_without_0x_prefix

# 钱包地址 (可选，会从私钥自动生成)
WALLET_ADDRESS=0xyour_wallet_address

# ====== 3. MOLTBOOK (可选) ======
# 在 https://moltbook.com 获取
MOLTBOOK_API_KEY=your_moltbook_api_key
MOLTBOOK_OWNER_X=your_x_handle_without_at
MOLTBOOK_AGENT_NAME=FlashArb
MOLTBOOK_AGENT_WEBSITE=https://github.com/YOUR_USERNAME/xlayer-arbitrage-bot
MOLTBOOK_SUBMOLT=buildx
MOLTBOOK_PROXY=http://127.0.0.1:7890
MOLTBOOK_MOCK_MODE=false

# ====== 4. 交易设置 ======
# 交易金额 (USDC)
TRADE_AMOUNT=1

# 最小套利差价 (0.001 = 0.1%)
MIN_SPREAD=0.001

# 检查间隔 (秒)
CHECK_INTERVAL=5

# ====== 5. X Layer ======
CHAIN_ID=196
RPC_URL=https://rpc.xlayer.com

# ====== 6. 模式 ======
# true = 模拟 (不亏钱)
# false = 真实交易
MOCK_MODE=true
